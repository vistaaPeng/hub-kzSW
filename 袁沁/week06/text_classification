from transformers import AutoTokenizer, AutoModelForCausalLM, TrainingArguments, Trainer
from peft import LoraConfig, get_peft_model, TaskType
import torch

# 以Qwen2-0.5B为例（可换为ChatGLM3-6B）
model_name = "Qwen/Qwen2-0.5B-Instruct"
tokenizer = AutoTokenizer.from_pretrained(model_name, trust_remote_code=True)
model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=torch.bfloat16,
    device_map="auto",
    trust_remote_code=True
)

# 配置LoRA
lora_config = LoraConfig(
    task_type=TaskType.CAUSAL_LM,
    r=8,
    lora_alpha=32,
    lora_dropout=0.1,
    target_modules=["q_proj", "v_proj"]  # 不同模型需调整
)
model = get_peft_model(model, lora_config)

# 构造指令格式数据（将分类转为生成）
def format_instruction(text, label=None):
    prompt = f"判断以下评论的情感，只回答'正向'或'负向'：\n{text}\n情感："
    if label is not None:
        return prompt + ("正向" if label==1 else "负向")
    return prompt

# 训练集处理（需将文本转为input_ids，并计算labels）
def tokenize_function(examples):
    inputs = [format_instruction(t, l) for t, l in zip(examples['text'], examples['label'])]
    model_inputs = tokenizer(inputs, truncation=True, padding='max_length', max_length=256)
    # labels = input_ids（因果LM）
    model_inputs['labels'] = model_inputs['input_ids'].copy()
    return model_inputs

# 假设有DataFrame train_df, test_df
# from datasets import Dataset
# train_dataset = Dataset.from_pandas(train_df).map(tokenize_function, batched=True)

# 训练参数
training_args = TrainingArguments(
    output_dir="./llm_results",
    num_train_epochs=3,
    per_device_train_batch_size=1,
    gradient_accumulation_steps=4,
    logging_steps=10,
    save_strategy="epoch",
    learning_rate=2e-4,
    fp16=True,
)

# Trainer训练
trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=train_dataset,
    # eval_dataset=...
)
trainer.train()

# 推理测试
def predict(text):
    prompt = format_instruction(text)
    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)
    outputs = model.generate(**inputs, max_new_tokens=3)
    return tokenizer.decode(outputs[0], skip_special_tokens=True)[-2:]  # 取"正向"/"负向"

print("LLM预测结果:", predict("这部电影太棒了！"))
